# Prevent directory listing
Options -Indexes

# Protect configuration files and SQL backups
<FilesMatch "\.(sql|db|bak|bat|json|git|gitignore)$">
    <IfModule authz_core_module>
        Require all denied
    </IfModule>
    <IfModule !authz_core_module>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Protect config folder
RewriteEngine On
RewriteRule ^config/ - [F,L]
